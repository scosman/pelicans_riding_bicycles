<section class="masthead">
  <h1 class="masthead__title">{{ site.name }}</h1>
  <p class="masthead__tagline">{{ site.tagline }}</p>
</section>

<section class="collection" aria-labelledby="collection-heading">
  <h2 id="collection-heading">The Collection</h2>
  <p class="collection__subtitle">Five specimens, presented in order of accession.</p>
  {% for specimen in gallery %}
    {% include "partials/specimen.njk" %}
  {% endfor %}
</section>

<section class="curatorial-note" aria-labelledby="corpus-heading">
  <h2 id="corpus-heading">On the Corpus</h2>
  <p>
    The collection assembled above is the result of an exhaustive comparative review undertaken by the Curatorial Committee. Hundreds of candidate works were considered; five were judged to meet the threshold for accession. The corpus is intentionally small. It is intended to be authoritative rather than comprehensive.
  </p>
  <p>
    Submissions for accession review are accepted on a continuous basis. Those who believe they are in possession of a candidate specimen are warmly directed to the <a href="{{ '/contributing/' | url }}">Contributing</a> page, which sets out the prevailing accession procedure.
  </p>
</section>

<section class="seal" aria-label="Official seal">
  <img src="{{ '/assets/seal.png' | url }}" alt="The official seal of the Pelicans Riding Bicycles Enthusiasts Club" width="200">
  <p class="seal__caption">Official Seal of the Club</p>
</section>
