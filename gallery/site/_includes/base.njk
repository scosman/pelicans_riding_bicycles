<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {{ site.abbreviation }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  <link rel="icon" type="image/png" href="{{ '/assets/seal.png' | url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:wght@400;500&display=swap">
  <link rel="stylesheet" href="{{ '/assets/styles.css' | url }}">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  {% include "partials/header.njk" %}
  <main id="main">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
</body>
</html>
